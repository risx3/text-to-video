# Copy this file to .env and adjust values for your environment.
# All variables use the TTV_ prefix.

# ── Server ────────────────────────────────────────────────────────────────────
TTV_HOST=0.0.0.0
TTV_PORT=8000
TTV_DEBUG=false

# ── Compute device ────────────────────────────────────────────────────────────
# "auto"  → auto-detect: cuda > mps > cpu  (default)
# "cuda"  → NVIDIA GPU (Linux / Windows)
# "mps"   → Apple Silicon GPU (macOS)
# "cpu"   → CPU-only (slow, but works everywhere)
TTV_DEVICE=auto

# ── Models ────────────────────────────────────────────────────────────────────
TTV_MOTION_ADAPTER_ID=ByteDance/AnimateDiff-Lightning
TTV_BASE_MODEL_ID=runwayml/stable-diffusion-v1-5
# float16 is recommended for GPU; use float32 on CPU (set automatically when device=cpu)
TTV_TORCH_DTYPE=float16

# ── Generation defaults ───────────────────────────────────────────────────────
TTV_NUM_FRAMES=8
TTV_WIDTH=512
TTV_HEIGHT=512
# 4 or 8 for AnimateDiff-Lightning (distilled); must match the loaded checkpoint
TTV_NUM_INFERENCE_STEPS=8
# Keep at 1.0 for AnimateDiff-Lightning; higher values degrade quality
TTV_GUIDANCE_SCALE=1.0
TTV_FPS=8

# ── LLM prompt enhancement (Apple Silicon / mlx-lm only) ─────────────────────
# Set to false on non-Apple hosts or if you want to skip enhancement entirely
TTV_ENABLE_LLM=true
TTV_LLM_MODEL_ID=mlx-community/Qwen2.5-1.5B-Instruct-4bit
TTV_LLM_MAX_TOKENS=200
TTV_LLM_TEMP=0.7
